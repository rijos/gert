<Project>

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- Nullable diagnostics are errors even if TreatWarningsAsErrors is ever relaxed (#4, full coverage). -->
    <WarningsAsErrors>$(WarningsAsErrors);nullable</WarningsAsErrors>
  </PropertyGroup>

  <!-- Centralized library package versions (U4a). Orchestrator pins valid net10.0 versions. -->
  <PropertyGroup>
    <MicrosoftDataSqliteVersion>9.0.0</MicrosoftDataSqliteVersion>
    <DapperVersion>2.1.66</DapperVersion>
    <MicrosoftExtensionsOptionsVersion>9.0.0</MicrosoftExtensionsOptionsVersion>
    <!-- U7a: AddGertServices DI extension + validator resolution. Abstractions only (no host coupling). -->
    <MicrosoftExtensionsDIAbstractionsVersion>9.0.0</MicrosoftExtensionsDIAbstractionsVersion>
    <!-- U6: fail-closed FluentValidation provider + per-DTO validators. Orchestrator pins a valid net10.0 11.x. -->
    <FluentValidationVersion>11.11.0</FluentValidationVersion>
    <FluentValidationDIVersion>11.11.0</FluentValidationDIVersion>
    <!-- U8 auth: orchestrator pins a valid net10.0 version. -->
    <JwtBearerVersion>10.0.0</JwtBearerVersion>
  </PropertyGroup>

  <!-- One-type-per-file enforcement (#11). Only SA1402/SA1649 are on (see .editorconfig);
       all other StyleCop rules are silenced. analyzers-only, not a runtime dependency. -->
  <ItemGroup>
    <PackageReference Include="StyleCop.Analyzers" Version="1.2.0-beta.556">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
  </ItemGroup>

</Project>
