{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Gert": {
    "Vllm": {
      "BaseUrl": "http://localhost:8000",
      "ChatModelId": "default",
      "EmbeddingModelId": "bge-m3",
      "EmbeddingDimensions": 1024
    },
    "Search": {
      "BaseUrl": "http://localhost:8080",
      "FetchPages": false
    },
    "Sandbox": {
      "RunscPath": "runsc",
      "EgressEnabled": false
    },
    "Extractor": {
      "HelperPath": "gert-extract"
    }
  }
}
