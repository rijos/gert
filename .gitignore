# Build output
bin/
obj/

# Dev-only secrets (JWT signing keys etc.) - never commit
.dev/

# User-specific / IDE
*.user
.vs/
.claude/

# Local config overrides (may contain secrets)
appsettings.*.local.json

# Test output
TestResults/

# Python
.venv/
__pycache__/

# Coverage / build artifacts - E2E traces/screenshots, coverage reports, and the
# transpiled SPA dev mirror (artifacts/webroot). ANCHORED to the repo root so it can
# never swallow source dirs (e.g. the canvas viewer modules under
# components/canvas/artifacts/), which would then 404 in CI.
/artifacts/
/tools/smoke/artifacts/

# Python editable-install metadata
*.egg-info/
