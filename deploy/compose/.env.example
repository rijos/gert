# Copy to .env and fill in. NEVER commit .env (it holds secrets - F8).
# Generate secrets:  openssl rand -base64 32   (Artifacts)  /  openssl rand -hex 32  (SearXNG)

# --- Public hostnames (need DNS A/AAAA records pointing at this host) ---
GERT_DOMAIN=gert.example.com
ARTIFACTS_DOMAIN=artifacts.example.com
ID_DOMAIN=id.example.com
ACME_EMAIL=admin@example.com

# --- OIDC client id (must match the client you create in Pocket ID; it is also the
#     expected access-token `aud`). See deploy/README.md "Pocket ID setup". ---
GERT_OIDC_CLIENT_ID=gert

# --- Secrets ---
ARTIFACTS_SECRET=        # >=32 bytes; openssl rand -base64 32
SEARXNG_SECRET=          # openssl rand -hex 32

# --- Chat upstream (EXTERNAL, OpenAI-compatible /v1/chat/completions) ---
GERT_CHAT_NAME=Default
GERT_CHAT_BASEURL=https://your-vllm.example.com/v1
GERT_CHAT_MODEL=qwen3
GERT_CHAT_APIKEY=        # blank for a keyless vLLM

# --- Embeddings upstream (EXTERNAL, OpenAI-compatible /v1/embeddings) ---
GERT_EMBED_BASEURL=https://your-embeddings.example.com/v1
GERT_EMBED_MODEL=bge-m3
GERT_EMBED_DIMENSIONS=1024
GERT_EMBED_APIKEY=       # blank for a keyless upstream
