{
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    }
  },
  "Storage": {
    "DataRoot": ""
  },
  "Tools": {
    "DefaultGrant": [ "rag", "search", "sandbox" ]
  },
  "Gert": {
    "Vllm": {
      "BaseUrl": "http://localhost:8000",
      "ChatModelId": "default",
      "EmbeddingModelId": "bge-m3",
      "EmbeddingDimensions": 1024
    },
    "Search": {
      "BaseUrl": "http://localhost:8080",
      "FetchPages": false
    },
    "Sandbox": {
      "Backend": "monty",
      "Monty": {
        "BaseUrl": "http://localhost:8077"
      },
      "RunscPath": "runsc",
      "EgressEnabled": false
    },
    "Extractor": {
      "HelperPath": "gert-extract"
    }
  }
}
