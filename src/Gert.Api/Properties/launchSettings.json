{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "Gert.Api": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "http://localhost:5217",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "FakeE2E": {
      "$comment": "E2E profile (testing.md §4.2). The REAL Gert.External adapters run, but point at the Python mock upstreams; the host trusts the git-ignored dev JWKS that tools/smoke/tokens.py generates, validating python-minted tokens offline through the real RS256/JWKS path. NEVER a Production profile.",
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "http://127.0.0.1:5217;http://127.0.0.1:5218",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "DOTNET_ENVIRONMENT": "Development",

        "Auth__Authority": "https://id.dev.local",
        "Auth__Audience": "gert-api",
        "Gert__Dev__JwksPath": ".dev/jwt/dev-jwks.json",

        "$comment_artifacts": "F3: HTML artifacts render on a SEPARATE origin. In prod this is a sandbox subdomain; in dev/CI a second Kestrel port (:5218) is a genuinely distinct origin, so the browser enforces the real cross-origin boundary.",
        "Artifacts__Origin": "http://127.0.0.1:5218",

        "Gert__Vllm__BaseUrl": "http://127.0.0.1:8000",
        "Gert__Search__BaseUrl": "http://127.0.0.1:8080",

        "Gert__Models__0__Id": "default",
        "Gert__Models__0__Name": "Echo Server",
        "Gert__Models__0__Default": "true",
        "Gert__Models__0__Endpoint": ":8000",
        "Gert__Models__0__Capabilities__0": "text only",
        "Gert__Models__0__Context": "0",

        "Storage__DataRoot": ".dev/e2e-data",

        "Gert__Web__TestHarness": "true"
      }
    }
  }
}
