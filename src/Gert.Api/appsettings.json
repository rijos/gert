{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Gert": {
    // Operator model catalog for the picker (rest-api.md § models). When absent or
    // empty, GET /api/models falls back to the single Gert:Vllm:ChatModelId entry.
    // Entry shape: { "Id", "Name", "Default", "Fast", "Endpoint", "Capabilities": [], "Context" }
    "Models": [],
    "Vllm": {
      "BaseUrl": "http://localhost:8000",
      "ChatModelId": "default",
      "EmbeddingModelId": "bge-m3",
      "EmbeddingDimensions": 1024
    },
    "Search": {
      "BaseUrl": "http://localhost:8080",
      "FetchPages": false
    },
    "Sandbox": {
      // Which backend ISandbox resolves to: "monty" (default — Pydantic's Rust Python
      // interpreter via the sidecar below; no container infra) or "gvisor" (runsc).
      "Backend": "monty",
      "Monty": {
        "BaseUrl": "http://localhost:8077"
      },
      "RunscPath": "runsc",
      "EgressEnabled": false
    },
    "Extractor": {
      "HelperPath": "gert-extract"
    }
  }
}
