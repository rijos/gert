{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Gert": {
    "Database": {
      // Functionality -> Type. Which engine the per-user/per-project databases use:
      // "Sqlite" (default - per-user SQLite files under the Storage data-root below).
      // A future server engine ("Postgres") is a sibling plugin selected here; its
      // connection string is a secret (F8) - env / user-secrets, never appsettings.
      "Type": "Sqlite"
    },
    "Rag": {
      // Functionality -> Type. The vector/RAG index engine, decoupled from the SQL
      // database above (vector stores need not be SQL): "Sqlite" (default - per-project
      // sqlite-vec + FTS5). A dedicated vector store (e.g. "Qdrant") is a sibling plugin.
      "Type": "Sqlite"
    },
    "Chat": {
      // Chat provider catalog for the picker - a map keyed by provider slug, each
      // { Name, Type, Fast?, Capabilities?, Context?, Parameters }. Each Parameters bag
      // carries that provider's connection, sampling, and its own RequestTimeoutSeconds /
      // RetryCount (per-item HTTP resilience). "DefaultProvider" (a slug, sibling of
      // Providers) is the picker's default; unset -> first entry, unknown -> startup error.
      // Empty Providers -> GET /api/models falls back to one default OpenAI provider
      // synthesized from Gert:Embeddings:Parameters:BaseUrl. Full schema + qwen36
      // thinking/instruct examples: installation/configuration.md section providers.
      "Providers": {}
    },
    "Embeddings": {
      // Functionality -> Type -> Parameters. Only "OpenAI" ships (an OpenAI-compatible
      // /v1/embeddings upstream). ApiKey is a secret (F8): env / user-secrets only.
      "Type": "OpenAI",
      "Parameters": {
        "BaseUrl": "http://localhost:8000",
        "Model": "bge-m3",
        "Dimensions": 1024,
        "RequestTimeoutSeconds": 120,
        "RetryCount": 2
      }
    },
    "Tools": {
      "Search": {
        // Only "SearXNG" ships. FetchPages + the SSRF fetch caps sit beside Type (they
        // also bound web_fetch); only the connection lives under Parameters.
        "Type": "SearXNG",
        "FetchPages": false,
        "Parameters": {
          "BaseUrl": "http://localhost:8080"
        }
      },
      "Sandbox": {
        // Which backend the run_python sandbox uses: "Monty" (default - Pydantic's Rust
        // Python interpreter via the sidecar; no container infra) or "GVisor" (runsc).
        // The cross-backend caps (WallClockSeconds / MemoryMiB / MaxOutputBytes) sit
        // beside Type; the per-backend bag lives under Parameters (Monty: BaseUrl +
        // RequestTimeoutSeconds; GVisor: RunscPath / Image / CpuSeconds / PidLimit /
        // TmpSizeMiB / EgressEnabled).
        "Type": "Monty",
        "Parameters": {
          "BaseUrl": "http://localhost:8077"
        }
      }
    },
    "Extractor": {
      // Only "Subprocess" ships (the unprivileged pdf/docx helper). The caps + hardening
      // knobs live under Parameters.
      "Type": "Subprocess",
      "Parameters": {
        "HelperPath": "gert-extract"
      }
    }
  }
}
