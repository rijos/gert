{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Gert": {
    // Chat provider catalog for the picker - a map keyed by provider slug, each
    // { Name, Type, Default?, Fast?, Capabilities?, Context?, Parameters }. Empty ->
    // GET /api/models falls back to one default openai provider from Gert:OpenAI:BaseUrl.
    // Full schema + qwen36 thinking/instruct examples: installation/configuration.md
    // section providers. `make serve-mock-vllm` generates presets per detected model.
    "Providers": {},
    // Embeddings connection + the shared chat-transport resilience defaults
    // (RequestTimeoutSeconds / RetryCount). Chat connection + sampling live per
    // provider above; this section carries no chat model id.
    "OpenAI": {
      "BaseUrl": "http://localhost:8000",
      "EmbeddingModelId": "bge-m3",
      "EmbeddingDimensions": 1024
    },
    "Search": {
      "BaseUrl": "http://localhost:8080",
      "FetchPages": false
    },
    "Sandbox": {
      // Which backend ISandbox resolves to: "monty" (default - Pydantic's Rust Python
      // interpreter via the sidecar below; no container infra) or "gvisor" (runsc).
      "Backend": "monty",
      "Monty": {
        "BaseUrl": "http://localhost:8077"
      },
      "RunscPath": "runsc",
      "EgressEnabled": false
    },
    "Extractor": {
      "HelperPath": "gert-extract"
    }
  }
}
