    <ProjectReference Include="..\..\src\Gert.Database.Sqlite\Gert.Database.Sqlite.csproj" />
    <ProjectReference Include="..\..\src\Gert.Api\Gert.Api.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Pinned versions (valid net10.0). -->
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" Version="$(AspNetTestingVersion)" />
    <PackageReference Include="Microsoft.IdentityModel.JsonWebTokens" Version="$(IdentityModelVersion)" />
    <PackageReference Include="Microsoft.IdentityModel.Tokens" Version="$(IdentityModelVersion)" />
  </ItemGroup>

