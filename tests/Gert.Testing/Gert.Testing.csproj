<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <!-- WebApplicationFactory<Program> needs the ASP.NET Core shared framework. -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Gert.Service\Gert.Service.csproj" />
    <ProjectReference Include="..\..\Gert.Model\Gert.Model.csproj" />
    <ProjectReference Include="..\..\Gert.Api\Gert.Api.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Versions pinned by the orchestrator (valid net10.0). See U3 report. -->
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" Version="$(AspNetTestingVersion)" />
    <PackageReference Include="Microsoft.IdentityModel.JsonWebTokens" Version="$(IdentityModelVersion)" />
    <PackageReference Include="Microsoft.IdentityModel.Tokens" Version="$(IdentityModelVersion)" />
  </ItemGroup>

</Project>
