  <!-- WebApplicationFactory<Program> needs the ASP.NET Core shared framework. -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Gert.Service\Gert.Service.csproj" />
    <ProjectReference Include="..\..\src\Gert.Model\Gert.Model.csproj" />
    <!-- Fakes (FakeChatModel/FakeEmbeddings/FixedChatClientFactory) implement the chat ports. -->
